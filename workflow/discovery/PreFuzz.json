{
    "Id": "PreFuzz",
    "Mode": "Discovery",
    "RequestTemplate": {
        "Method": "GET",
        "UrlTemplate": "BASE",
        "Header": {
            "User-Agent": "DEFAULT"
        }
    },
    "ResponseAction": {
        "ScreenShotConditions": [
            {
                "Field": "StatusCode",
                "Condition": "OneOf",
                "Values": ["200"]
            }
        ],
        "FactConditions": [
            {
                "Conditions": [
                    {
                        "Field": "StatusCode",
                        "Condition": "OneOf",
                        "Values": ["200", "204", "301", "302", "307", "401", "405"]
                    }
                ],
                "Facts": {
                    "Exists": "true"
                }
            },
            {
                "Conditions": [
                    {
                        "Field": "StatusCode",
                        "Condition": "OneOf",
                        "Values": ["301", "302", "303", "307", "308"]
                    }
                ],
                "Facts": {
                    "Redirects": "HdrLocation"
                }
            }
        ],
        "JobConditions": [
            {
                "Conditions": [
                    {
                        "Field": "StatusCode",
                        "Condition": "OneOf",
                        "Values": ["200", "204", "301", "302", "307", "401"]
                    },
                    {
                        "Field": "FuzzRecursive",
                        "Condition": "Equals",
                        "Values": ["true"]
                    }
                ],
                "Jobs": [
                    {
                        "Action": "FuzzFiles",
                        "Priority": 5,
                        "Target": "CURRENT"
                    },
                    {
                        "Action": "FuzzDirectories",
                        "Priority": 5,
                        "Target": "CURRENT"
                    }
                ]
            }
        ]
    }
}
